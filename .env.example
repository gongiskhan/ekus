# Copy this to .env and fill in your keys
# .env is gitignored — never commit secrets

# OpenAI (for Whisper, image gen)
OPENAI_API_KEY=sk-...

# ElevenLabs (TTS)
ELEVENLABS_API_KEY=sk_...

# Trello
TRELLO_KEY=your_api_key
TRELLO_TOKEN=your_token

# Brave Search (optional)
BRAVE_API_KEY=...

# Google (optional, if not using MCP)
GOOGLE_API_KEY=...

# Octa Manager (for invoice uploads)
# Get token: open manager.octacode.pt → browser console → localStorage.getItem('authToken')
OCTA_TOKEN=...

# Slack
SLACK_BOT_TOKEN=xoxb-...
